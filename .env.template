# Local ZeroClaw + Ollama defaults

# Ollama model to pull and use for the local provider.
# Use `auto` only if you already have at least one model installed in Ollama.
ZEROCLAW_MODEL=phi4-mini

# Gateway port exposed from the ZeroClaw container.
ZEROCLAW_GATEWAY_PORT=42617

# Host port mapped to the ZeroClaw gateway.
HOST_PORT=42617

# Internal endpoint used by ZeroClaw to reach Ollama over the compose network.
ZEROCLAW_API_ENDPOINT=http://ollama-brain:11434

# Ollama tuning.
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=5m
OLLAMA_DEBUG=0

# Per-role model defaults (override per-service in docker-compose or via .env)
ZEROCLAW_MODEL_COORDINATOR=tinyllama
ZEROCLAW_MODEL_CODER=phi4-mini
ZEROCLAW_MODEL_DEPLOYER=phi4-mini
ZEROCLAW_MODEL_TESTER=tinyllama

# ZeroClaw logging.
RUST_LOG=info

# Pre-flight thresholds for constrained environments.
REQUIRED_RAM_GB=2
MIN_REQUIRED_DISK_GB=3
RECOMMENDED_DISK_GB=5
